{
  "id": "bollinger_reversion_bot_v1",
  "name": "볼린저밴드 역추세 자동매매 (텔레그램)",
  "description": "대형 기술주 6종목 감시. 볼린저밴드 하단 터치 시 과매도 매수, 보유종목 순환 매도. 30분 간격 자동화.",
  "nodes": [
    {"id": "start", "type": "StartNode", "position": {"x": 50, "y": 300}},
    {
      "id": "broker",
      "type": "OverseasStockBrokerNode",
      "credential_id": "broker_cred",
      "paper_trading": false,
      "position": {"x": 200, "y": 300}
    },
    {
      "id": "schedule",
      "type": "ScheduleNode",
      "cron": "*/30 * * * 1-5",
      "timezone": "America/New_York",
      "enabled": true,
      "max_duration_hours": 720,
      "position": {"x": 400, "y": 300}
    },
    {
      "id": "trading_hours",
      "type": "TradingHoursFilterNode",
      "start": "09:30",
      "end": "15:55",
      "timezone": "America/New_York",
      "days": ["mon", "tue", "wed", "thu", "fri"],
      "position": {"x": 600, "y": 300}
    },

    {
      "id": "account",
      "type": "OverseasStockAccountNode",
      "position": {"x": 800, "y": 300}
    },

    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {"symbol": "SOFI", "exchange": "NASDAQ"},
        {"symbol": "RIVN", "exchange": "NASDAQ"},
        {"symbol": "LCID", "exchange": "NASDAQ"},
        {"symbol": "GRAB", "exchange": "NASDAQ"},
        {"symbol": "OPEN", "exchange": "NASDAQ"},
        {"symbol": "DNA", "exchange": "NYSE"}
      ],
      "position": {"x": 800, "y": 100}
    },
    {
      "id": "historical",
      "type": "OverseasStockHistoricalDataNode",
      "symbol": "{{ item }}",
      "start_date": "{{ date.ago(60, format='yyyymmdd') }}",
      "end_date": "{{ date.today(format='yyyymmdd') }}",
      "interval": "1d",
      "position": {"x": 1050, "y": 100}
    },
    {
      "id": "bollinger",
      "type": "ConditionNode",
      "plugin": "BollingerBands",
      "items": {
        "from": "{{ item.time_series }}",
        "extract": {
          "symbol": "{{ item.symbol }}",
          "exchange": "{{ item.exchange }}",
          "date": "{{ row.date }}",
          "close": "{{ row.close }}"
        }
      },
      "fields": {
        "period": 20,
        "std_dev": 2.0,
        "position": "below_lower"
      },
      "position": {"x": 1300, "y": 100}
    },

    {
      "id": "filter_buy",
      "type": "SymbolFilterNode",
      "operation": "difference",
      "input_a": "{{ nodes.bollinger.passed_symbols }}",
      "input_b": "{{ nodes.account.held_symbols }}",
      "position": {"x": 1550, "y": 200}
    },
    {
      "id": "buy_order",
      "type": "OverseasStockNewOrderNode",
      "side": "buy",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": 1
      },
      "position": {"x": 1800, "y": 200}
    },
    {
      "id": "telegram_buy",
      "type": "TelegramNode",
      "credential_id": "telegram_cred",
      "template": "📉 볼린저 하단 터치 매수 (SOFI, RIVN, LCID, GRAB, OPEN, DNA)",
      "position": {"x": 2050, "y": 200}
    },

    {
      "id": "account_sell",
      "type": "OverseasStockAccountNode",
      "position": {"x": 800, "y": 500}
    },
    {
      "id": "sell_order",
      "type": "OverseasStockNewOrderNode",
      "side": "{{ item.close_side }}",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": "{{ item.quantity }}"
      },
      "resilience": {
        "fallback": {"mode": "skip"}
      },
      "position": {"x": 1050, "y": 500}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "schedule"},
    {"from": "schedule", "to": "trading_hours"},

    {"from": "trading_hours", "to": "account"},
    {"from": "trading_hours", "to": "watchlist"},

    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "bollinger"},

    {"from": "bollinger", "to": "filter_buy"},
    {"from": "account", "to": "filter_buy"},
    {"from": "filter_buy", "to": "buy_order"},
    {"from": "buy_order", "to": "telegram_buy"},

    {"from": "trading_hours", "to": "account_sell"},
    {"from": "account_sell", "to": "sell_order"}
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_stock",
      "data": [
        {"key": "appkey", "value": "", "type": "password", "label": "App Key"},
        {"key": "appsecret", "value": "", "type": "password", "label": "App Secret"}
      ]
    },
    {
      "credential_id": "telegram_cred",
      "type": "telegram",
      "data": [
        {"key": "bot_token", "value": "", "type": "password", "label": "Bot Token"},
        {"key": "chat_id", "value": "", "type": "text", "label": "Chat ID"}
      ]
    }
  ],
  "notes": [
    {
      "id": "note_strategy",
      "content": "## 볼린저밴드 역추세 자동매매\n\n**전략**: 평균회귀 (Mean Reversion)\n\n**매수**: watchlist 6종목 볼린저밴드(20,2) 평가\n  → 하단 밴드 이하 = 과매도\n  → 보유종목 제외 후 매수 (1주)\n\n**매도**: 보유 포지션 전량 청산\n  (다음 사이클에 조건 재평가)\n\n**주기**: 30분 (평일 09:30-15:55 ET)\n\n**종목**: AAPL, MSFT, GOOGL, AMZN, NVDA, META",
      "color": 3,
      "width": 360,
      "height": 280,
      "position": {"x": 30, "y": 30}
    }
  ]
}

# ProgramGarden 예제 환경변수
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.

# ===== LS증권 API =====
APPKEY=your-ls-securities-appkey
APPSECRET=your-ls-securities-appsecret

# ===== Telegram Bot =====
# @BotFather에서 봇 생성 후 토큰 획득
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# 채팅방 ID (개인: 숫자, 그룹: -100으로 시작)
TELEGRAM_CHAT_ID=-1001234567890

# ===== Supabase PostgreSQL =====
SUPABASE_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USERNAME=postgres
SUPABASE_PASSWORD=your-supabase-password

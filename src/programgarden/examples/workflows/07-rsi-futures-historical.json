{
  "id": "rsi-futures-historical",
  "name": "RSI 조건 - 해외선물 과거데이터",
  "description": "항셍/H지수 선물 RSI 과매도 조건 - table 차트",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "position": {
        "x": 200,
        "y": 200
      },
      "provider": "ls-sec.co.kr",
      "product": "overseas_futures",
      "credential_id": "2126e9c2-3da4-4da7-9d98-e6fead52e4ac"
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "position": {
        "x": 350,
        "y": 100
      },
      "symbols": [
        {
          "exchange": "HKEX",
          "symbol": "HSIG26"
        },
        {
          "exchange": "HKEX",
          "symbol": "HHIG26"
        }
      ]
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "position": {
        "x": 550,
        "y": 200
      },
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ months_ago_yyyymmdd(6) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "customLabel": "과거 데이터"
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "position": {
        "x": 750,
        "y": 200
      },
      "plugin": "RSI",
      "fields": {
        "period": 14,
        "threshold": 30,
        "direction": "below"
      },
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "symbols": "{{ nodes.watchlist.symbols }}"
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "position": {
        "x": 950,
        "y": 200
      },
      "chart_type": "multi_line",
      "title": "선물 RSI 결과",
      "data": "{{ flatten(nodes.rsiCondition.values, 'time_series') }}",
      "columns": [
        "symbol",
        "exchange",
        "rsi",
        "current_price"
      ],
      "x_field": "date",
      "y_field": "rsi",
      "series_key": "symbol"
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "watchlist"
    },
    {
      "from": "watchlist",
      "to": "historical"
    },
    {
      "from": "historical",
      "to": "rsiCondition"
    },
    {
      "from": "rsiCondition",
      "to": "display"
    }
  ],
  "credentials": [
    {
      "id": "2126e9c2-3da4-4da7-9d98-e6fead52e4ac",
      "type": "broker_ls",
      "name": "LS 해외선물 모의투자",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": ""
      }
    }
  ]
}
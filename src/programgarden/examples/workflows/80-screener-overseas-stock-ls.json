{
  "id": "80-screener-overseas-stock-ls",
  "name": "해외주식 스크리너 (LS g3190 마스터 + 시가총액 필터)",
  "description": "OverseasStockBrokerNode → OverseasStockSymbolQueryNode (NASDAQ 마스터 g3190) → ScreenerNode(market='overseas_stock', data_source='ls'): LS g3190 응답의 가격/시가총액으로 빠르게 필터링. data_source='ls' 분기의 정석 입력 패턴 (WatchlistNode 단독은 price/market_cap 정보가 없어 권장하지 않음).",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "OverseasStockBrokerNode",
      "credential_id": "broker_cred",
      "position": {
        "x": 250,
        "y": 200
      }
    },
    {
      "id": "universe",
      "type": "OverseasStockSymbolQueryNode",
      "country": "US",
      "stock_exchange": "81",
      "max_results": 500,
      "position": {
        "x": 500,
        "y": 200
      }
    },
    {
      "id": "screener",
      "type": "ScreenerNode",
      "market": "overseas_stock",
      "data_source": "ls",
      "symbols": "{{ nodes.universe.symbols }}",
      "market_cap_min": 10000000000,
      "price_min": 50.0,
      "max_results": 20,
      "position": {
        "x": 750,
        "y": 200
      }
    },
    {
      "id": "display",
      "type": "TableDisplayNode",
      "title": "해외주식 스크리닝 결과 (LS 마스터 + 대형주 필터)",
      "columns": [
        "symbol",
        "exchange",
        "price",
        "market_cap"
      ],
      "data": "{{ nodes.screener.symbols }}",
      "position": {
        "x": 1000,
        "y": 200
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "universe"
    },
    {
      "from": "universe",
      "to": "screener"
    },
    {
      "from": "screener",
      "to": "display"
    }
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_stock",
      "data": [
        {
          "key": "appkey",
          "value": "",
          "type": "password",
          "label": "App Key"
        },
        {
          "key": "appsecret",
          "value": "",
          "type": "password",
          "label": "App Secret"
        }
      ]
    }
  ]
}

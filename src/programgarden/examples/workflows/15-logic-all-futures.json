{
  "id": "logic-all-futures",
  "version": "1.0.0",
  "name": "LogicNode ALL(AND) - 해외선물",
  "description": "선물 RSI + MACD 모두 만족해야 통과",
  "tags": ["logic", "all", "and", "overseas_futures", "table"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_futures",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "HKEX", "symbol": "HSIG26"},
        {"exchange": "HKEX", "symbol": "HHIG26"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ months_ago_yyyymmdd(3) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 500, "y": 200}
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "RSI",
      "fields": {"period": 14, "threshold": 30, "direction": "below"},
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 700, "y": 100}
    },
    {
      "id": "macdCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "MACD",
      "fields": {"fast_period": 12, "slow_period": 26, "signal_period": 9, "signal": "bullish_cross"},
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 700, "y": 300}
    },
    {
      "id": "logic",
      "type": "LogicNode",
      "category": "condition",
      "operator": "all",
      "conditions": ["rsiCondition", "macdCondition"],
      "position": {"x": 900, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "선물 Logic ALL 결과",
      "data": "{{ nodes.logic.details }}",
      "position": {"x": 1100, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "rsiCondition"},
    {"from": "historical", "to": "macdCondition"},
    {"from": "rsiCondition", "to": "logic"},
    {"from": "macdCondition", "to": "logic"},
    {"from": "logic", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 선물 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": true}
    }
  ]
}

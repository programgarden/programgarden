{
  "id": "30-liquidate-futures-positions",
  "name": "해외선물 포지션 전량 청산",
  "description": "보유 중인 해외선물 포지션을 전량 청산 (모의투자) - auto-iterate 활용, HKEX는 시장가 불가하여 지정가 사용",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "OverseasFuturesBrokerNode",
      "credential_id": "futures_cred",
      "paper_trading": true,
      "position": {
        "x": 250,
        "y": 200
      }
    },
    {
      "id": "account",
      "type": "OverseasFuturesAccountNode",
      "position": {
        "x": 450,
        "y": 200
      }
    },
    {
      "id": "close_order",
      "type": "OverseasFuturesNewOrderNode",
      "side": "{{ item.close_side }}",
      "order_type": "limit",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": "{{ item.quantity }}",
        "price": "{{ item.current_price }}"
      },
      "position": {
        "x": 700,
        "y": 200
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "account"
    },
    {
      "from": "account",
      "to": "close_order"
    }
  ],
  "credentials": [
    {
      "credential_id": "futures_cred",
      "type": "broker_ls_overseas_futures",
      "data": [
        {
          "key": "appkey",
          "value": "",
          "type": "password",
          "label": "App Key"
        },
        {
          "key": "appsecret",
          "value": "",
          "type": "password",
          "label": "App Secret"
        }
      ]
    }
  ]
}

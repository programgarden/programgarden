{
  "name": "벤치마크 비교 (RSI vs SPY Buy&Hold)",
  "version": "1.0.0",
  "description": "RSI 과매도 전략과 SPY Buy&Hold 벤치마크를 비교합니다. BenchmarkCompareNode를 사용하여 전략 성과를 비교 분석합니다.",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "position": {
        "x": 200,
        "y": 200
      },
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "{{ credentials[0].id }}"
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "position": {
        "x": 350,
        "y": 150
      },
      "connection": "{{ nodes.broker.connection }}",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "AAPL"},
        {"exchange": "NASDAQ", "symbol": "NVDA"},
        {"exchange": "NASDAQ", "symbol": "MSFT"}
      ]
    },
    {
      "id": "watchlistSPY",
      "type": "WatchlistNode",
      "category": "symbol",
      "position": {
        "x": 350,
        "y": 350
      },
      "connection": "{{ nodes.broker.connection }}",
      "symbols": [
        {"exchange": "AMEX", "symbol": "SPY"}
      ]
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "data",
      "position": {
        "x": 500,
        "y": 150
      },
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ months_ago_yyyymmdd(6) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d"
    },
    {
      "id": "historicalSPY",
      "type": "HistoricalDataNode",
      "category": "data",
      "position": {
        "x": 500,
        "y": 350
      },
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlistSPY.symbols }}",
      "start_date": "{{ months_ago_yyyymmdd(6) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d"
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "position": {
        "x": 650,
        "y": 150
      },
      "plugin": "RSI",
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "fields": {
        "period": 14,
        "oversold": 30,
        "overbought": 70
      }
    },
    {
      "id": "backtestRSI",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "position": {
        "x": 800,
        "y": 150
      },
      "initial_capital": 10000,
      "commission_rate": 0.001,
      "slippage": 0.0005,
      "position_sizing": "equal_weight",
      "strategy_name": "RSI 과매도 전략",
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "signals": "{{ nodes.rsiCondition.signals }}"
    },
    {
      "id": "backtestSPY",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "position": {
        "x": 800,
        "y": 350
      },
      "initial_capital": 10000,
      "commission_rate": 0.001,
      "slippage": 0.0005,
      "position_sizing": "equal_weight",
      "strategy_name": "SPY Buy&Hold",
      "data": "{{ flatten(nodes.historicalSPY.values, 'time_series') }}"
    },
    {
      "id": "compare",
      "type": "BenchmarkCompareNode",
      "category": "analysis",
      "position": {
        "x": 1000,
        "y": 250
      },
      "strategies": [
        "{{ nodes.backtestRSI }}",
        "{{ nodes.backtestSPY }}"
      ],
      "ranking_metric": "sharpe"
    },
    {
      "id": "displayComparison",
      "type": "DisplayNode",
      "category": "display",
      "position": {
        "x": 1200,
        "y": 200
      },
      "chart_type": "multi_line",
      "title": "전략 비교: RSI vs SPY Buy&Hold",
      "data": "{{ nodes.compare.combined_curve }}",
      "x_field": "date",
      "y_field": "values"
    },
    {
      "id": "displayRanking",
      "type": "DisplayNode",
      "category": "display",
      "position": {
        "x": 1200,
        "y": 350
      },
      "chart_type": "table",
      "title": "전략 순위",
      "data": "{{ nodes.compare.comparison_metrics }}",
      "columns": ["label", "return", "sharpe", "mdd", "calmar"]
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "broker", "to": "watchlistSPY"},
    {"from": "watchlist", "to": "historical"},
    {"from": "watchlistSPY", "to": "historicalSPY"},
    {"from": "historical", "to": "rsiCondition"},
    {"from": "rsiCondition", "to": "backtestRSI"},
    {"from": "historicalSPY", "to": "backtestSPY"},
    {"from": "backtestRSI", "to": "compare"},
    {"from": "backtestSPY", "to": "compare"},
    {"from": "compare", "to": "displayComparison"},
    {"from": "compare", "to": "displayRanking"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS 해외주식",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": false
      }
    }
  ]
}

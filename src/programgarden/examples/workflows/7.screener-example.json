{
  "id": "screener-example",
  "name": "조건으로 종목찾기 예제",
  "description": "시가총액 100억 달러 이상, 거래량 100만주 이상인 기술주를 검색합니다. ScreenerNode는 Yahoo Finance를 사용하므로 broker 연결이 필요 없습니다.",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {"x": 100, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-stock",
      "position": {"x": 300, "y": 100}
    },
    {
      "id": "screener",
      "type": "ScreenerNode",
      "market_cap_min": 10000000000,
      "volume_min": 1000000,
      "sector": "Technology",
      "exchange": "NASDAQ",
      "max_results": 20,
      "position": {"x": 300, "y": 300}
    },
    {
      "id": "marketData",
      "type": "MarketDataNode",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.screener.symbols }}",
      "fields": ["price", "volume"],
      "position": {"x": 500, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "start", "to": "screener"},
    {"from": "broker", "to": "marketData"},
    {"from": "screener", "to": "marketData"}
  ],
  "credentials": [
    {
      "id": "broker-stock",
      "type": "broker_ls",
      "name": "LS증권 해외주식",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": false
      }
    }
  ]
}

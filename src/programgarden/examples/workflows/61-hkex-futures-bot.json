{
  "id": "hkex_futures_bot_v1",
  "name": "HKEX 미니선물 역추세 자동매매 (모의투자)",
  "description": "미니항셍·미니H주 2종목 볼린저밴드 역추세. 하단 터치 시 롱 진입, 보유 포지션 순환 청산. 30분 간격 모의투자.",
  "nodes": [
    {"id": "start", "type": "StartNode", "position": {"x": 50, "y": 300}},
    {
      "id": "broker",
      "type": "OverseasFuturesBrokerNode",
      "credential_id": "broker_cred",
      "paper_trading": true,
      "position": {"x": 200, "y": 300}
    },
    {
      "id": "schedule",
      "type": "ScheduleNode",
      "cron": "*/30 * * * 1-5",
      "timezone": "Asia/Hong_Kong",
      "enabled": true,
      "max_duration_hours": 720,
      "position": {"x": 400, "y": 300}
    },
    {
      "id": "trading_hours",
      "type": "TradingHoursFilterNode",
      "start": "09:15",
      "end": "16:30",
      "timezone": "Asia/Hong_Kong",
      "days": ["mon", "tue", "wed", "thu", "fri"],
      "position": {"x": 600, "y": 300}
    },

    {
      "id": "account",
      "type": "OverseasFuturesAccountNode",
      "position": {"x": 800, "y": 300}
    },

    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {"symbol": "HMHJ26", "exchange": "HKEX"},
        {"symbol": "HMCEJ26", "exchange": "HKEX"}
      ],
      "position": {"x": 800, "y": 100}
    },
    {
      "id": "historical",
      "type": "OverseasFuturesHistoricalDataNode",
      "symbol": "{{ item }}",
      "start_date": "{{ date.ago(60, format='yyyymmdd') }}",
      "end_date": "{{ date.today(format='yyyymmdd') }}",
      "interval": "1d",
      "position": {"x": 1050, "y": 100}
    },
    {
      "id": "bollinger",
      "type": "ConditionNode",
      "plugin": "BollingerBands",
      "items": {
        "from": "{{ item.time_series }}",
        "extract": {
          "symbol": "{{ item.symbol }}",
          "exchange": "{{ item.exchange }}",
          "date": "{{ row.date }}",
          "close": "{{ row.close }}"
        }
      },
      "fields": {
        "period": 20,
        "std_dev": 2.0,
        "position": "below_lower"
      },
      "position": {"x": 1300, "y": 100}
    },

    {
      "id": "filter_buy",
      "type": "SymbolFilterNode",
      "operation": "difference",
      "input_a": "{{ nodes.bollinger.passed_symbols }}",
      "input_b": "{{ nodes.account.held_symbols }}",
      "position": {"x": 1550, "y": 200}
    },
    {
      "id": "buy_order",
      "type": "OverseasFuturesNewOrderNode",
      "side": "buy",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": 1
      },
      "position": {"x": 1800, "y": 200}
    },
    {
      "id": "telegram_buy",
      "type": "TelegramNode",
      "credential_id": "telegram_cred",
      "template": "📈 HKEX 미니선물 롱 진입 (볼린저 하단 터치)",
      "position": {"x": 2050, "y": 200}
    },

    {
      "id": "account_sell",
      "type": "OverseasFuturesAccountNode",
      "position": {"x": 800, "y": 500}
    },
    {
      "id": "sell_order",
      "type": "OverseasFuturesNewOrderNode",
      "side": "{{ item.close_side }}",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": "{{ item.quantity }}"
      },
      "resilience": {
        "fallback": {"mode": "skip"}
      },
      "position": {"x": 1050, "y": 500}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "schedule"},
    {"from": "schedule", "to": "trading_hours"},

    {"from": "trading_hours", "to": "account"},
    {"from": "trading_hours", "to": "watchlist"},

    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "bollinger"},

    {"from": "bollinger", "to": "filter_buy"},
    {"from": "account", "to": "filter_buy"},
    {"from": "filter_buy", "to": "buy_order"},
    {"from": "buy_order", "to": "telegram_buy"},

    {"from": "trading_hours", "to": "account_sell"},
    {"from": "account_sell", "to": "sell_order"}
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_futures",
      "data": [
        {"key": "appkey", "value": "", "type": "password", "label": "App Key"},
        {"key": "appsecret", "value": "", "type": "password", "label": "App Secret"}
      ]
    },
    {
      "credential_id": "telegram_cred",
      "type": "telegram",
      "data": [
        {"key": "bot_token", "value": "", "type": "password", "label": "Bot Token"},
        {"key": "chat_id", "value": "", "type": "text", "label": "Chat ID"}
      ]
    }
  ],
  "notes": [
    {
      "id": "note_strategy",
      "content": "## HKEX 미니선물 역추세 봇 (모의투자)\n\n**전략**: 볼린저밴드(20,2) 평균회귀\n\n**매수(롱)**: 미니항셍·미니H주 볼린저 하단 터치\n  → 과매도 = 롱 1계약\n  → 보유 포지션 제외\n\n**청산**: 보유 포지션 전량 반대매매\n\n**주기**: 30분 (평일 09:15-16:30 HKT)\n\n**종목**: HMHJ26 (미니항셍 4월), HMCEJ26 (미니H주 4월)\n**틱가치**: 10 HKD (~$1.3)",
      "color": 5,
      "width": 360,
      "height": 300,
      "position": {"x": 30, "y": 30}
    }
  ]
}

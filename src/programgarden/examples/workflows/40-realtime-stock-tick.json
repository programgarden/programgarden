{
  "id": "40-realtime-stock-tick",
  "name": "해외주식 실시간 틱 (실전)",
  "description": "해외주식 실시간 GSC 틱 데이터 수신 확인. AAPL (NASDAQ) 구독. 주의: 해외주식 실시간은 모의투자 미지원 (LS증권 API 제한), 실전만 가능.",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "OverseasStockBrokerNode",
      "credential_id": "broker_cred",
      "position": {
        "x": 250,
        "y": 200
      }
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {
          "exchange": "NASDAQ",
          "symbol": "AAPL"
        }
      ],
      "position": {
        "x": 500,
        "y": 200
      }
    },
    {
      "id": "realtime",
      "type": "OverseasStockRealMarketDataNode",
      "stay_connected": true,
      "position": {
        "x": 750,
        "y": 200
      }
    },
    {
      "id": "throttle",
      "type": "ThrottleNode",
      "mode": "latest",
      "interval_sec": 3,
      "pass_first": true,
      "position": {
        "x": 1000,
        "y": 200
      }
    },
    {
      "id": "display",
      "type": "TableDisplayNode",
      "data": "{{ nodes.throttle.data }}",
      "position": {
        "x": 1250,
        "y": 200
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "watchlist"
    },
    {
      "from": "watchlist",
      "to": "realtime"
    },
    {
      "from": "realtime",
      "to": "throttle"
    },
    {
      "from": "throttle",
      "to": "display"
    }
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_stock",
      "data": [
        {
          "key": "appkey",
          "value": "",
          "type": "password",
          "label": "App Key"
        },
        {
          "key": "appsecret",
          "value": "",
          "type": "password",
          "label": "App Secret"
        }
      ]
    }
  ]
}

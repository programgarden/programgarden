{
  "id": "condition-rsi-stock",
  "name": "RSI 조건 테스트 - 해외주식",
  "description": "HistoricalDataNode → ConditionNode(RSI) 통합 테스트. DisplayNode-like data + field_mapping 패턴 사용.",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {"x": 100, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-stock",
      "position": {"x": 300, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "AAPL"},
        {"exchange": "NASDAQ", "symbol": "TSLA"}
      ],
      "position": {"x": 500, "y": 200}
    },
    {
      "id": "historicaldata_1",
      "type": "HistoricalDataNode",
      "connection": "{{ nodes.broker.connection }}",
      "interval": "1d",
      "start_date": "dynamic:days_ago(100)",
      "end_date": "dynamic:today()",
      "position": {"x": 700, "y": 200}
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "plugin": "RSI",
      "data": "{{ flatten(nodes.historicaldata_1.values, 'time_series') }}",
      "close_field": "close",
      "date_field": "date",
      "symbol_field": "symbol",
      "exchange_field": "exchange",
      "fields": {
        "period": 14,
        "threshold": 30,
        "direction": "below"
      },
      "position": {"x": 900, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historicaldata_1"},
    {"from": "historicaldata_1", "to": "rsiCondition"}
  ],
  "credentials": [
    {
      "id": "broker-stock",
      "type": "broker_ls",
      "name": "LS증권 해외주식",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": false
      }
    }
  ]
}

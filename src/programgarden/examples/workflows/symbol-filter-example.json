{
  "id": "symbol-filter-example",
  "name": "종목 비교/필터 예제",
  "description": "관심종목과 보유종목을 비교하여 아직 보유하지 않은 종목만 골라냅니다. 중복 매수 방지에 활용됩니다.",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {"x": 100, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-stock",
      "position": {"x": 300, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "AAPL"},
        {"exchange": "NASDAQ", "symbol": "NVDA"},
        {"exchange": "NASDAQ", "symbol": "TSLA"},
        {"exchange": "NASDAQ", "symbol": "MSFT"},
        {"exchange": "NYSE", "symbol": "PLTR"}
      ],
      "position": {"x": 500, "y": 100}
    },
    {
      "id": "account",
      "type": "AccountNode",
      "connection": "{{ nodes.broker.connection }}",
      "product_type": "overseas_stock",
      "position": {"x": 500, "y": 300}
    },
    {
      "id": "filter",
      "type": "SymbolFilterNode",
      "operation": "difference",
      "input_a": "{{ nodes.watchlist.symbols }}",
      "input_b": "{{ nodes.account.held_symbols }}",
      "position": {"x": 750, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "broker", "to": "account"},
    {"from": "watchlist", "to": "filter"},
    {"from": "account", "to": "filter"}
  ],
  "credentials": [
    {
      "id": "broker-stock",
      "type": "broker_ls",
      "name": "LS증권 해외주식",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": false
      }
    }
  ]
}

{
  "id": "macd-futures-backtest",
  "version": "1.0.0",
  "name": "MACD 백테스트 - 해외선물",
  "description": "선물 MACD 기반 매매 시뮬레이션 + equity_curve 차트",
  "tags": ["condition", "macd", "backtest", "overseas_futures", "equity_curve"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_futures",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "HKEX", "symbol": "HSIG26"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ days_ago_yyyymmdd(180) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 550, "y": 200}
    },
    {
      "id": "macdCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "MACD",
      "mode": "backtest",
      "fields": {"fast_period": 12, "slow_period": 26, "signal_period": 9, "signal": "bullish_cross"},
      "ohlcv_data": "{{ nodes.historical.ohlcv_data }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 750, "y": 200}
    },
    {
      "id": "backtest",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "initial_capital": 50000,
      "commission_rate": 0.0005,
      "ohlcv_data": "{{ nodes.historical.ohlcv_data }}",
      "signals": "{{ nodes.macdCondition.signals }}",
      "position": {"x": 950, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "equity_curve",
      "title": "선물 MACD 전략 자산곡선",
      "data": "{{ nodes.backtest.equity_curve }}",
      "x_field": "date",
      "y_field": "equity",
      "position": {"x": 1150, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "macdCondition"},
    {"from": "macdCondition", "to": "backtest"},
    {"from": "backtest", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 선물 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": true}
    }
  ]
}

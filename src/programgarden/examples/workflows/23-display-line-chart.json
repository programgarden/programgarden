{
  "id": "23-display-line-chart",
  "name": "라인 차트 (RSI)",
  "description": "LineChartNode로 RSI 시계열 차트 표시",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "OverseasStockBrokerNode",
      "credential_id": "broker_cred",
      "position": {
        "x": 200,
        "y": 200
      }
    },
    {
      "id": "historical",
      "type": "OverseasStockHistoricalDataNode",
      "symbol": {
        "symbol": "AAPL",
        "exchange": "NASDAQ"
      },
      "period": "1d",
      "start_date": "{{ date.ago(30, format='yyyymmdd') }}",
      "end_date": "{{ date.today(format='yyyymmdd') }}",
      "position": {
        "x": 400,
        "y": 200
      }
    },
    {
      "id": "condition",
      "type": "ConditionNode",
      "plugin": "RSI",
      "data": "{{ nodes.historical.values }}",
      "params": {
        "period": 14,
        "overbought": 70,
        "oversold": 30
      },
      "position": {
        "x": 600,
        "y": 200
      }
    },
    {
      "id": "chart",
      "type": "LineChartNode",
      "title": "AAPL RSI (14일)",
      "data": "{{ nodes.condition.values }}",
      "x_field": "date",
      "y_field": "rsi",
      "signal_field": "signal",
      "position": {
        "x": 800,
        "y": 200
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "historical"
    },
    {
      "from": "historical",
      "to": "condition"
    },
    {
      "from": "condition",
      "to": "chart"
    }
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_stock",
      "data": [
        {
          "key": "appkey",
          "value": "",
          "type": "password",
          "label": "App Key"
        },
        {
          "key": "appsecret",
          "value": "",
          "type": "password",
          "label": "App Secret"
        }
      ]
    }
  ]
}

    {
      "id": "tsmom_cond",
      "type": "ConditionNode",
      "plugin": "TSMOM",
      "items": {
        "from": "{{ item.time_series }}",
        "extract": {
          "symbol": "{{ item.symbol }}",
          "exchange": "{{ item.exchange }}",
          "date": "{{ row.date }}",
          "open": "{{ row.open }}",
          "high": "{{ row.high }}",
          "low": "{{ row.low }}",
          "close": "{{ row.close }}",
          "volume": "{{ row.volume }}"
        }
      },
      "fields": {
        "lookback": 60,
        "volatility_lookback": 20,
        "threshold": 0.0,
        "volatility_target": 0.15,
        "direction": "long"
      },
      "position": {
        "x": 1500,
        "y": 150
      }
    },
    {
      "id": "rsi_cond",
      "type": "ConditionNode",
      "plugin": "RSI",

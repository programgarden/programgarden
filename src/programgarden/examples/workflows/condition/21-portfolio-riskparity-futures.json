{
  "id": "portfolio-risk-parity-futures",
  "version": "1.0.0",
  "name": "PortfolioNode 리스크패리티 - 해외선물",
  "description": "변동성 역비례 배분 포트폴리오 (리스크 패리티)",
  "tags": ["portfolio", "risk_parity", "backtest", "overseas_futures", "equity_curve"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 250}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_futures",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 250}
    },
    {
      "id": "watchlistNQ",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [{"exchange": "CME", "symbol": "NQH25"}],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "watchlistES",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [{"exchange": "CME", "symbol": "ESH25"}],
      "position": {"x": 350, "y": 400}
    },
    {
      "id": "historicalNQ",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlistNQ.symbols }}",
      "start_date": "{{ days_ago_yyyymmdd(180) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 550, "y": 100}
    },
    {
      "id": "historicalES",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlistES.symbols }}",
      "start_date": "{{ days_ago_yyyymmdd(180) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 550, "y": 400}
    },
    {
      "id": "backtestNQ",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "initial_capital": 25000,
      "commission_rate": 0.0005,
      "ohlcv_data": "{{ nodes.historicalNQ.ohlcv_data }}",
      "position": {"x": 750, "y": 100}
    },
    {
      "id": "backtestES",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "initial_capital": 25000,
      "commission_rate": 0.0005,
      "ohlcv_data": "{{ nodes.historicalES.ohlcv_data }}",
      "position": {"x": 750, "y": 400}
    },
    {
      "id": "portfolio",
      "type": "PortfolioNode",
      "category": "risk",
      "total_capital": 50000,
      "allocation_method": "risk_parity",
      "rebalance_rule": "drift",
      "drift_threshold": 5.0,
      "strategy_results": [
        "{{ nodes.backtestNQ.equity_curve }}",
        "{{ nodes.backtestES.equity_curve }}"
      ],
      "position": {"x": 950, "y": 250}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "equity_curve",
      "title": "리스크패리티 포트폴리오 자산곡선",
      "data": "{{ nodes.portfolio.combined_equity }}",
      "x_field": "date",
      "y_field": "equity",
      "position": {"x": 1150, "y": 250}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlistNQ"},
    {"from": "broker", "to": "watchlistES"},
    {"from": "watchlistNQ", "to": "historicalNQ"},
    {"from": "watchlistES", "to": "historicalES"},
    {"from": "historicalNQ", "to": "backtestNQ"},
    {"from": "historicalES", "to": "backtestES"},
    {"from": "backtestNQ", "to": "portfolio"},
    {"from": "backtestES", "to": "portfolio"},
    {"from": "portfolio", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 선물 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": true}
    }
  ]
}

{
  "id": "rsi-stock-backtest",
  "version": "1.0.0",
  "name": "RSI 백테스트 - 해외주식",
  "description": "RSI 기반 매매 시뮬레이션 + equity_curve 차트",
  "tags": ["condition", "rsi", "backtest", "overseas_stock", "equity_curve"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "AAPL"},
        {"exchange": "NASDAQ", "symbol": "MSFT"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ days_ago_yyyymmdd(365) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 550, "y": 200}
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "RSI",
      "mode": "backtest",
      "fields": {"period": 14, "threshold": 30, "direction": "below"},
      "ohlcv_data": "{{ nodes.historical.ohlcv_data }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 750, "y": 200}
    },
    {
      "id": "backtest",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "initial_capital": 10000,
      "commission_rate": 0.001,
      "ohlcv_data": "{{ nodes.historical.ohlcv_data }}",
      "signals": "{{ nodes.rsiCondition.signals }}",
      "position": {"x": 950, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "equity_curve",
      "title": "RSI 전략 자산곡선",
      "data": "{{ nodes.backtest.equity_curve }}",
      "x_field": "date",
      "y_field": "equity",
      "benchmark_field": "benchmark",
      "position": {"x": 1150, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "rsiCondition"},
    {"from": "rsiCondition", "to": "backtest"},
    {"from": "backtest", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

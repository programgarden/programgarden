{
  "id": "bollinger-stock-historical",
  "version": "1.0.0",
  "name": "볼린저밴드 조건 - 해외주식 과거데이터",
  "description": "볼린저밴드 하단 돌파 조건 평가 - candlestick 차트",
  "tags": ["condition", "bollinger", "historical", "overseas_stock", "candlestick"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "GOOGL"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ months_ago_yyyymmdd(3) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 550, "y": 200}
    },
    {
      "id": "bollingerCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "BollingerBands",
      "fields": {"period": 20, "num_std": 2.0, "signal": "below_lower"},
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 750, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "candlestick",
      "title": "GOOGL 가격 + 볼린저밴드",
      "data": "{{ flatten(nodes.bollingerCondition.values, 'time_series') }}",
      "x_field": "date",
      "open_field": "open",
      "high_field": "high",
      "low_field": "low",
      "close_field": "close",
      "overlay_fields": ["upper_band", "middle_band", "lower_band"],
      "position": {"x": 950, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "bollingerCondition"},
    {"from": "bollingerCondition", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

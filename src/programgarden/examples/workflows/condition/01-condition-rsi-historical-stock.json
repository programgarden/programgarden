{
  "id": "condition-rsi-historical-stock",
  "name": "RSI 조건 - 해외주식 과거데이터",
  "description": "HistoricalDataNode에서 과거 데이터의 마지막 시점으로 RSI 조건 평가",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "position": {
        "x": 200,
        "y": 200
      },
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "7c5caa90-f013-44fd-855d-410437c86737"
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "position": {
        "x": 350,
        "y": 100
      },
      "symbols": [
        {
          "exchange": "NASDAQ",
          "symbol": "AAPL"
        },
        {
          "exchange": "NASDAQ",
          "symbol": "TSLA"
        },
        {
          "exchange": "NASDAQ",
          "symbol": "NVDA"
        }
      ]
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "position": {
        "x": 750,
        "y": 200
      },
      "plugin": "RSI",
      "fields": {
        "period": 14,
        "threshold": 30,
        "direction": "below"
      },
      "data": "{{ flatten(nodes.historicaldata_1.values, 'time_series') }}"
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "position": {
        "x": 950,
        "y": 200
      },
      "chart_type": "multi_line",
      "title": "RSI 시계열",
      "data": "{{ flatten(nodes.rsiCondition.values, 'time_series') }}",
      "x_field": "date",
      "y_field": "rsi",
      "series_key": "symbol"
    },
    {
      "id": "historicaldata_1",
      "type": "HistoricalDataNode",
      "category": "market",
      "position": {
        "x": 540,
        "y": 60
      },
      "description": "N일치 일봉/주봉/월봉 OHLCV 차트 데이터.",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "dynamic:months_ago(3)",
      "end_date": "dynamic:today()",
      "interval": "1d",
      "adjust": true,
      "customLabel": "과거 데이터"
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "watchlist"
    },
    {
      "from": "rsiCondition",
      "to": "display"
    },
    {
      "from": "watchlist",
      "to": "historicaldata_1"
    },
    {
      "from": "historicaldata_1",
      "to": "rsiCondition"
    }
  ],
  "credentials": [
    {
      "id": "7c5caa90-f013-44fd-855d-410437c86737",
      "type": "broker_ls",
      "name": "LS 해외주식",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": ""
      }
    }
  ]
}
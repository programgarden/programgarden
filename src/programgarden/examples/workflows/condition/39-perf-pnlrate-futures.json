{
  "id": "perf-pnlrate-futures",
  "version": "1.0.0",
  "name": "PerformanceConditionNode pnl_rate - 해외선물",
  "description": "수익률 조건 - 선물 포지션 (수익률 > 2%)",
  "tags": ["performance", "pnl_rate", "overseas_futures"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_futures",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "realAccount",
      "type": "RealAccountNode",
      "category": "realtime",
      "connection": "{{ nodes.broker.connection }}",
      "stay_connected": false,
      "position": {"x": 400, "y": 200}
    },
    {
      "id": "perfCondition",
      "type": "PerformanceConditionNode",
      "category": "condition",
      "metric": "pnl_rate",
      "operator": "gt",
      "threshold": 2.0,
      "position_data": "{{ nodes.realAccount.positions }}",
      "position": {"x": 600, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "선물 수익률 조건 결과",
      "data": "{{ nodes.perfCondition.details }}",
      "position": {"x": 850, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "realAccount"},
    {"from": "realAccount", "to": "perfCondition"},
    {"from": "perfCondition", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 선물 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": true}
    }
  ]
}

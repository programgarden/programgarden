{
  "id": "logic-xor-stock",
  "version": "1.0.0",
  "name": "LogicNode xor - 해외주식",
  "description": "RSI, MACD 중 정확히 하나만 만족해야 통과 (XOR)",
  "tags": ["logic", "xor", "overseas_stock"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "AAPL"},
        {"exchange": "NASDAQ", "symbol": "TSLA"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "realMarket",
      "type": "RealMarketDataNode",
      "category": "realtime",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "stay_connected": false,
      "position": {"x": 500, "y": 200}
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "RSI",
      "fields": {"period": 14, "threshold": 30, "direction": "below"},
      "ohlcv_data": "{{ nodes.realMarket.ohlcv_data }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 700, "y": 100}
    },
    {
      "id": "macdCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "MACD",
      "fields": {"fast_period": 12, "slow_period": 26, "signal_period": 9, "signal": "bullish_cross"},
      "ohlcv_data": "{{ nodes.realMarket.ohlcv_data }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 700, "y": 300}
    },
    {
      "id": "logic",
      "type": "LogicNode",
      "category": "condition",
      "operator": "xor",
      "conditions": ["rsiCondition", "macdCondition"],
      "position": {"x": 900, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "Logic XOR 결과",
      "data": "{{ nodes.logic.details }}",
      "position": {"x": 1100, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "realMarket"},
    {"from": "realMarket", "to": "rsiCondition"},
    {"from": "realMarket", "to": "macdCondition"},
    {"from": "rsiCondition", "to": "logic"},
    {"from": "macdCondition", "to": "logic"},
    {"from": "logic", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

{
  "id": "profittarget-stock",
  "version": "1.0.0",
  "name": "익절 조건 - 해외주식 실시간",
  "description": "목표 수익률 10% 달성 시 익절 신호 - table 차트",
  "tags": ["condition", "profittarget", "realtime", "overseas_stock", "table"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "realAccount",
      "type": "RealAccountNode",
      "category": "realtime",
      "connection": "{{ nodes.broker.connection }}",
      "stay_connected": false,
      "position": {"x": 400, "y": 200}
    },
    {
      "id": "profitCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "ProfitTarget",
      "fields": {"target_percent": 10.0},
      "positions": "{{ nodes.realAccount.positions }}",
      "position": {"x": 600, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "익절 대상 종목",
      "data": "{{ nodes.profitCondition.passed_symbols }}",
      "columns": ["symbol", "exchange", "pnl_rate", "current_price"],
      "position": {"x": 850, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "realAccount"},
    {"from": "realAccount", "to": "profitCondition"},
    {"from": "profitCondition", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

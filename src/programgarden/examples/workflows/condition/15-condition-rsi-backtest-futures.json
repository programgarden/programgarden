{
  "id": "condition-rsi-backtest-futures",
  "version": "1.0.0",
  "name": "RSI 조건 - 백테스트 해외선물",
  "description": "HistoricalDataNode에서 과거 OHLCV를 받아 선물 RSI 조건 평가",
  "tags": ["condition", "rsi", "backtest", "overseas_futures"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_futures",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "CME", "symbol": "NQU25"},
        {"exchange": "CME", "symbol": "ESU25"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "data",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "interval": "1d",
      "start_date": "dynamic:days_ago(100)",
      "end_date": "dynamic:today()",
      "position": {"x": 550, "y": 200}
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "RSI",
      "mode": "backtest",
      "fields": {
        "period": 14,
        "threshold": 30,
        "direction": "below"
      },
      "ohlcv_data": "{{ nodes.historical.ohlcv_data }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 750, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "line",
      "title": "선물 RSI 백테스트 결과",
      "data": "{{ nodes.rsiCondition.signals }}",
      "position": {"x": 950, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "rsiCondition"},
    {"from": "rsiCondition", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 선물 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": true}
    }
  ]
}

{
  "id": "perf-winrate-stock",
  "version": "1.0.0",
  "name": "PerformanceConditionNode win_rate - 해외주식",
  "description": "승률 조건 (승률 >= 50%)",
  "tags": ["performance", "win_rate", "overseas_stock"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "account",
      "type": "AccountNode",
      "category": "account",
      "connection": "{{ nodes.broker.connection }}",
      "position": {"x": 400, "y": 200}
    },
    {
      "id": "perfCondition",
      "type": "PerformanceConditionNode",
      "category": "condition",
      "metric": "win_rate",
      "operator": "gte",
      "threshold": 50.0,
      "trade_history": "{{ nodes.account.trade_history }}",
      "position": {"x": 600, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "승률 조건 결과",
      "data": "{{ nodes.perfCondition.details }}",
      "position": {"x": 850, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "account"},
    {"from": "account", "to": "perfCondition"},
    {"from": "perfCondition", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

{
  "id": "logic-any-stock",
  "version": "1.0.0",
  "name": "LogicNode ANY(OR) - 해외주식",
  "description": "RSI 또는 VolumeSpike 하나라도 만족 시 통과",
  "tags": ["logic", "any", "or", "overseas_stock", "table"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "NVDA"},
        {"exchange": "NASDAQ", "symbol": "AMD"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ months_ago_yyyymmdd(3) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 500, "y": 200}
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "RSI",
      "fields": {"period": 14, "threshold": 30, "direction": "below"},
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 700, "y": 100}
    },
    {
      "id": "volumeCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "VolumeSpike",
      "fields": {"period": 20, "threshold_ratio": 2.0},
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 700, "y": 300}
    },
    {
      "id": "logic",
      "type": "LogicNode",
      "category": "condition",
      "operator": "any",
      "conditions": ["rsiCondition", "volumeCondition"],
      "position": {"x": 900, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "Logic ANY 결과",
      "data": "{{ nodes.logic.details }}",
      "position": {"x": 1100, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "rsiCondition"},
    {"from": "historical", "to": "volumeCondition"},
    {"from": "rsiCondition", "to": "logic"},
    {"from": "volumeCondition", "to": "logic"},
    {"from": "logic", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

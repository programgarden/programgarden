{
  "id": "condition-bollinger-backtest-stock",
  "version": "1.0.0",
  "name": "BollingerBands 조건 - 백테스트 해외주식",
  "description": "HistoricalDataNode에서 과거 OHLCV를 받아 볼린저밴드 조건 평가",
  "tags": ["condition", "bollinger", "backtest", "overseas_stock"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "AAPL"},
        {"exchange": "NASDAQ", "symbol": "TSLA"},
        {"exchange": "NASDAQ", "symbol": "NVDA"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "data",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "interval": "1d",
      "start_date": "dynamic:days_ago(100)",
      "end_date": "dynamic:today()",
      "position": {"x": 550, "y": 200}
    },
    {
      "id": "bollingerCondition",
      "type": "ConditionNode",
      "category": "condition",
      "plugin": "BollingerBands",
      "mode": "backtest",
      "fields": {
        "period": 20,
        "std": 2.0,
        "position": "below_lower"
      },
      "ohlcv_data": "{{ nodes.historical.ohlcv_data }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "position": {"x": 750, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "line",
      "title": "BollingerBands 백테스트 결과",
      "data": "{{ nodes.bollingerCondition.signals }}",
      "position": {"x": 950, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "bollingerCondition"},
    {"from": "bollingerCondition", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

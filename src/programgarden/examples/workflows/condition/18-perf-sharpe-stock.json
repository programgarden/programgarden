{
  "id": "perf-sharpe-stock",
  "version": "1.0.0",
  "name": "PerformanceCondition Sharpe - 해외주식",
  "description": "백테스트 샤프비율 > 1.0 조건",
  "tags": ["performance", "sharpe", "backtest", "overseas_stock", "bar"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "symbols": [
        {"exchange": "NASDAQ", "symbol": "MSFT"},
        {"exchange": "NASDAQ", "symbol": "AMZN"}
      ],
      "position": {"x": 350, "y": 100}
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ days_ago_yyyymmdd(365) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d",
      "position": {"x": 550, "y": 200}
    },
    {
      "id": "backtest",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "initial_capital": 10000,
      "commission_rate": 0.001,
      "ohlcv_data": "{{ nodes.historical.ohlcv_data }}",
      "position": {"x": 750, "y": 200}
    },
    {
      "id": "perfCondition",
      "type": "PerformanceConditionNode",
      "category": "condition",
      "metric": "sharpe_ratio",
      "operator": "gt",
      "threshold": 1.0,
      "summary": "{{ nodes.backtest.summary }}",
      "position": {"x": 950, "y": 200}
    },
    {
      "id": "display",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "bar",
      "title": "성과 지표 비교",
      "data": "{{ nodes.backtest.summary }}",
      "x_field": "metric",
      "y_field": "value",
      "position": {"x": 1150, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "backtest"},
    {"from": "backtest", "to": "perfCondition"},
    {"from": "perfCondition", "to": "display"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

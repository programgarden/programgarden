{
  "id": "realmarket-futures-test",
  "name": "RealMarketDataNode 해외선물 테스트",
  "description": "WebSocket OVC를 사용한 실시간 시세 수신 테스트 (모의투자)",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {"x": 100, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "provider": "ls-sec.co.kr",
      "product": "overseas_futures",
      "credential_id": "broker-futures",
      "position": {"x": 300, "y": 200}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {"exchange": "HKEX", "symbol": "HSIG26"},
        {"exchange": "HKEX", "symbol": "HCEIG26"},
        {"exchange": "HKEX", "symbol": "HTIG26"}
      ],
      "position": {"x": 500, "y": 200}
    },
    {
      "id": "realMarket",
      "type": "RealMarketDataNode",
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "stay_connected": true,
      "position": {"x": 700, "y": 200}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "watchlist"},
    {"from": "watchlist", "to": "realMarket"}
  ],
  "credentials": [
    {
      "id": "broker-futures",
      "type": "broker_ls",
      "name": "LS증권 해외선물 (모의투자)",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": true
      }
    }
  ]
}

{
  "id": "35-ai-agent-strategist",
  "name": "AI 전략본부장 (종합 판단)",
  "description": "strategist 프리셋으로 계좌/시세/과거데이터를 종합 분석하고 매매 판단 수행",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {
        "x": 50,
        "y": 300
      }
    },
    {
      "id": "broker",
      "type": "OverseasStockBrokerNode",
      "credential_id": "broker_cred",
      "position": {
        "x": 250,
        "y": 400
      }
    },
    {
      "id": "llm",
      "type": "LLMModelNode",
      "credential_id": "llm_cred",
      "model": "claude-haiku-4-5-20251001",
      "temperature": 0.5,
      "max_tokens": 2000,
      "position": {
        "x": 250,
        "y": 150
      }
    },
    {
      "id": "account",
      "type": "OverseasStockAccountNode",
      "position": {
        "x": 500,
        "y": 500
      }
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {
          "symbol": "AAPL",
          "exchange": "NASDAQ"
        },
        {
          "symbol": "MSFT",
          "exchange": "NASDAQ"
        },
        {
          "symbol": "NVDA",
          "exchange": "NASDAQ"
        },
        {
          "symbol": "TSLA",
          "exchange": "NASDAQ"
        }
      ],
      "position": {
        "x": 250,
        "y": 600
      }
    },
    {
      "id": "market",
      "type": "OverseasStockMarketDataNode",
      "symbols": [
        {
          "symbol": "AAPL",
          "exchange": "NASDAQ"
        },
        {
          "symbol": "MSFT",
          "exchange": "NASDAQ"
        },
        {
          "symbol": "NVDA",
          "exchange": "NASDAQ"
        },
        {
          "symbol": "TSLA",
          "exchange": "NASDAQ"
        }
      ],
      "position": {
        "x": 500,
        "y": 350
      }
    },
    {
      "id": "historical",
      "type": "OverseasStockHistoricalDataNode",
      "symbol": "{{ item }}",
      "period": "1d",
      "start_date": "{{ date.ago(14, format='yyyymmdd') }}",
      "end_date": "{{ date.today(format='yyyymmdd') }}",
      "position": {
        "x": 500,
        "y": 200
      }
    },
    {
      "id": "open_orders",
      "type": "OverseasStockOpenOrdersNode",
      "position": {
        "x": 500,
        "y": 600
      }
    },
    {
      "id": "agent",
      "type": "AIAgentNode",
      "preset": "strategist",
      "user_prompt": "현재 포지션, 미체결 주문, 시세 데이터를 종합적으로 분석하고 다음 액션을 결정해주세요.\n\n관심 종목: AAPL, MSFT, NVDA, TSLA\n\n분석 시 다음을 고려하세요:\n1. 현재 포지션의 수익률과 리스크\n2. 미체결 주문 상태\n3. 시장 현재가 대비 기술적 위치\n4. 매수/매도/홀드 결정과 그 근거",
      "output_format": "structured",
      "output_schema": {
        "action": {
          "type": "string",
          "enum": [
            "buy",
            "sell",
            "hold"
          ],
          "description": "매매 판단"
        },
        "symbol": {
          "type": "string",
          "description": "대상 종목"
        },
        "quantity": {
          "type": "number",
          "description": "수량"
        },
        "price": {
          "type": "number",
          "description": "목표가"
        },
        "confidence": {
          "type": "number",
          "description": "확신도 (0~1)"
        },
        "reasoning": {
          "type": "string",
          "description": "판단 근거"
        }
      },
      "max_tool_calls": 10,
      "timeout_seconds": 120,
      "cooldown_sec": 300,
      "position": {
        "x": 800,
        "y": 300
      }
    },
    {
      "id": "result_table",
      "type": "TableDisplayNode",
      "title": "AI 전략 판단 결과",
      "data": "{{ nodes.agent.response }}",
      "position": {
        "x": 1100,
        "y": 300
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "start",
      "to": "llm"
    },
    {
      "from": "broker",
      "to": "account"
    },
    {
      "from": "broker",
      "to": "market"
    },
    {
      "from": "broker",
      "to": "open_orders"
    },
    {
      "from": "watchlist",
      "to": "historical"
    },
    {
      "from": "llm",
      "to": "agent",
      "type": "ai_model"
    },
    {
      "from": "account",
      "to": "agent",
      "type": "tool"
    },
    {
      "from": "market",
      "to": "agent",
      "type": "tool"
    },
    {
      "from": "historical",
      "to": "agent",
      "type": "tool"
    },
    {
      "from": "open_orders",
      "to": "agent",
      "type": "tool"
    },
    {
      "from": "agent",
      "to": "result_table"
    }
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_stock",
      "data": [
        {
          "key": "appkey",
          "value": "",
          "type": "password",
          "label": "App Key"
        },
        {
          "key": "appsecret",
          "value": "",
          "type": "password",
          "label": "App Secret"
        }
      ]
    },
    {
      "credential_id": "llm_cred",
      "type": "llm_anthropic",
      "data": [
        {
          "key": "api_key",
          "value": "",
          "type": "password",
          "label": "API Key"
        }
      ]
    }
  ]
}

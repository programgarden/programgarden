{
  "id": "31-liquidate-stock-positions",
  "name": "해외주식 포지션 전량 청산",
  "description": "보유 중인 해외주식 포지션을 전량 청산 (실전) - 매도는 시장가 가능",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "OverseasStockBrokerNode",
      "credential_id": "broker_cred",
      "position": {
        "x": 250,
        "y": 200
      }
    },
    {
      "id": "account",
      "type": "OverseasStockAccountNode",
      "position": {
        "x": 450,
        "y": 200
      }
    },
    {
      "id": "close_order",
      "type": "OverseasStockNewOrderNode",
      "side": "{{ item.close_side }}",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": "{{ item.quantity }}"
      },
      "position": {
        "x": 700,
        "y": 200
      }
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "account"
    },
    {
      "from": "account",
      "to": "close_order"
    }
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_stock",
      "data": [
        {
          "key": "appkey",
          "value": "",
          "type": "password",
          "label": "App Key"
        },
        {
          "key": "appsecret",
          "value": "",
          "type": "password",
          "label": "App Secret"
        }
      ]
    }
  ]
}

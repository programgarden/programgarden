{
  "id": "realaccount-display-stock",
  "version": "1.0.0",
  "name": "실시간 포지션 DisplayNode - 해외주식",
  "description": "RealAccountNode + DisplayNode 실시간 보유종목",
  "tags": ["realtime", "account", "display", "overseas_stock", "table"],
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {"x": 50, "y": 200}
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "broker-cred",
      "position": {"x": 200, "y": 200}
    },
    {
      "id": "realAccount",
      "type": "RealAccountNode",
      "category": "realtime",
      "connection": "{{ nodes.broker.connection }}",
      "stay_connected": true,
      "sync_interval_sec": 60,
      "position": {"x": 400, "y": 200}
    },
    {
      "id": "displayPositions",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "보유종목 실시간 수익률",
      "data": "{{ nodes.realAccount.positions }}",
      "columns": ["symbol", "quantity", "buy_price", "current_price", "pnl_rate"],
      "realtime_update": true,
      "position": {"x": 650, "y": 100}
    },
    {
      "id": "displayBalance",
      "type": "DisplayNode",
      "category": "display",
      "chart_type": "table",
      "title": "예수금 정보",
      "data": "{{ nodes.realAccount.balance }}",
      "position": {"x": 650, "y": 300}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "realAccount"},
    {"from": "realAccount", "to": "displayPositions"},
    {"from": "realAccount", "to": "displayBalance"}
  ],
  "credentials": [
    {
      "id": "broker-cred",
      "type": "broker_ls",
      "name": "LS증권 API",
      "data": {"appkey": "", "appsecret": "", "paper_trading": false}
    }
  ]
}

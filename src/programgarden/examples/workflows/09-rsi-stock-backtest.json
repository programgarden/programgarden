{
  "id": "rsi-stock-backtest",
  "name": "RSI 백테스트 + 벤치마크 비교",
  "description": "RSI 전략 vs Buy&Hold 벤치마크 비교 분석",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "category": "infra",
      "position": {
        "x": 50,
        "y": 200
      }
    },
    {
      "id": "broker",
      "type": "BrokerNode",
      "category": "infra",
      "position": {
        "x": 200,
        "y": 200
      },
      "provider": "ls-sec.co.kr",
      "product": "overseas_stock",
      "credential_id": "7c5caa90-f013-44fd-855d-410437c86737"
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "category": "symbol",
      "position": {
        "x": 350,
        "y": 100
      },
      "symbols": [
        {
          "exchange": "NASDAQ",
          "symbol": "AAPL"
        }
      ]
    },
    {
      "id": "historical",
      "type": "HistoricalDataNode",
      "category": "market",
      "position": {
        "x": 550,
        "y": 200
      },
      "connection": "{{ nodes.broker.connection }}",
      "symbols": "{{ nodes.watchlist.symbols }}",
      "start_date": "{{ days_ago_yyyymmdd(500) }}",
      "end_date": "{{ today_yyyymmdd() }}",
      "interval": "1d"
    },
    {
      "id": "rsiCondition",
      "type": "ConditionNode",
      "category": "condition",
      "position": {
        "x": 750,
        "y": 100
      },
      "plugin": "RSI",
      "mode": "backtest",
      "fields": {
        "period": 14,
        "threshold": 30,
        "direction": "below"
      },
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "symbols": "{{ nodes.watchlist.symbols }}"
    },
    {
      "id": "backtest_rsi",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "position": {
        "x": 950,
        "y": 100
      },
      "initial_capital": 10000,
      "commission_rate": 0.001,
      "slippage": 0.0005,
      "position_sizing": "equal_weight",
      "risk_free_rate": 0.02,
      "allow_short": false,
      "allow_fractional": true,
      "strategy_name": "RSI 과매도 전략",
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}",
      "signals": "{{ nodes.rsiCondition.signals }}"
    },
    {
      "id": "backtest_buyhold",
      "type": "BacktestEngineNode",
      "category": "backtest",
      "position": {
        "x": 950,
        "y": 300
      },
      "initial_capital": 10000,
      "commission_rate": 0.001,
      "slippage": 0.0005,
      "position_sizing": "equal_weight",
      "risk_free_rate": 0.02,
      "allow_short": false,
      "allow_fractional": true,
      "strategy_name": "Buy & Hold",
      "data": "{{ flatten(nodes.historical.values, 'time_series') }}"
    },
    {
      "id": "benchmark_compare",
      "type": "BenchmarkCompareNode",
      "category": "analysis",
      "position": {
        "x": 1200,
        "y": 200
      },
      "strategies": [
        {
          "strategy_name": "RSI 과매도 전략",
          "equity_curve": "{{ nodes.backtest_rsi.equity_curve }}"
        },
        {
          "strategy_name": "Buy & Hold",
          "equity_curve": "{{ nodes.backtest_buyhold.equity_curve }}"
        }
      ],
      "ranking_metric": "sharpe"
    },
    {
      "id": "display_metrics",
      "type": "DisplayNode",
      "category": "display",
      "position": {
        "x": 1450,
        "y": 100
      },
      "chart_type": "table",
      "title": "전략 비교 지표",
      "data": "{{ nodes.benchmark_compare.comparison_metrics }}"
    },
    {
      "id": "display_ranking",
      "type": "DisplayNode",
      "category": "display",
      "position": {
        "x": 1450,
        "y": 300
      },
      "chart_type": "table",
      "title": "전략 순위 (Sharpe 기준)",
      "data": "{{ nodes.benchmark_compare.ranking }}"
    }
  ],
  "edges": [
    {
      "from": "start",
      "to": "broker"
    },
    {
      "from": "broker",
      "to": "watchlist"
    },
    {
      "from": "watchlist",
      "to": "historical"
    },
    {
      "from": "historical",
      "to": "rsiCondition"
    },
    {
      "from": "historical",
      "to": "backtest_buyhold"
    },
    {
      "from": "rsiCondition",
      "to": "backtest_rsi"
    },
    {
      "from": "backtest_rsi",
      "to": "benchmark_compare"
    },
    {
      "from": "backtest_buyhold",
      "to": "benchmark_compare"
    },
    {
      "from": "benchmark_compare",
      "to": "display_metrics"
    },
    {
      "from": "benchmark_compare",
      "to": "display_ranking"
    }
  ],
  "credentials": [
    {
      "id": "7c5caa90-f013-44fd-855d-410437c86737",
      "type": "broker_ls",
      "name": "LS 해외주식",
      "data": {
        "appkey": "",
        "appsecret": "",
        "paper_trading": ""
      }
    }
  ]
}
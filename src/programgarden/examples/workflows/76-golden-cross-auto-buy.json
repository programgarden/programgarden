{
  "id": "76-golden-cross-auto-buy",
  "name": "골든크로스 자동 매수 (MA5/MA20, 선물 모의)",
  "description": "MA5 가 MA20 을 상향 돌파 (골든크로스) 시 자동 매수 + 텔레그램 알림. 추세 추종 자동화 튜토리얼.",
  "nodes": [
    {
      "id": "start",
      "type": "StartNode",
      "position": {"x": 50, "y": 300}
    },
    {
      "id": "broker",
      "type": "OverseasFuturesBrokerNode",
      "credential_id": "broker_cred",
      "paper_trading": true,
      "position": {"x": 250, "y": 300}
    },
    {
      "id": "schedule",
      "type": "ScheduleNode",
      "cron": "0 10 * * 1-5",
      "timezone": "Asia/Hong_Kong",
      "enabled": true,
      "max_duration_hours": 24,
      "position": {"x": 450, "y": 300}
    },
    {
      "id": "account",
      "type": "OverseasFuturesAccountNode",
      "position": {"x": 650, "y": 500}
    },
    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {"symbol": "HMHJ26", "exchange": "HKEX"},
        {"symbol": "HMCEJ26", "exchange": "HKEX"}
      ],
      "position": {"x": 650, "y": 100}
    },
    {
      "id": "historical",
      "type": "OverseasFuturesHistoricalDataNode",
      "symbol": "{{ item }}",
      "start_date": "{{ date.ago(60, format='yyyymmdd') }}",
      "end_date": "{{ date.today(format='yyyymmdd') }}",
      "interval": "1d",
      "position": {"x": 900, "y": 100}
    },
    {
      "id": "ma_cross",
      "type": "ConditionNode",
      "plugin": "MovingAverageCross",
      "items": {
        "from": "{{ item.time_series }}",
        "extract": {
          "symbol": "{{ item.symbol }}",
          "exchange": "{{ item.exchange }}",
          "date": "{{ row.date }}",
          "close": "{{ row.close }}"
        }
      },
      "fields": {
        "short_period": 5,
        "long_period": 20,
        "cross_type": "golden"
      },
      "position": {"x": 1150, "y": 100}
    },
    {
      "id": "filter_not_held",
      "type": "SymbolFilterNode",
      "operation": "difference",
      "input_a": "{{ nodes.ma_cross.passed_symbols }}",
      "input_b": "{{ nodes.account.held_symbols }}",
      "position": {"x": 1400, "y": 300}
    },
    {
      "id": "buy_order",
      "type": "OverseasFuturesNewOrderNode",
      "side": "buy",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": 1
      },
      "resilience": {
        "fallback": {"mode": "skip"}
      },
      "position": {"x": 1650, "y": 300}
    },
    {
      "id": "telegram_gc",
      "type": "TelegramNode",
      "credential_id": "telegram_cred",
      "template": "🌟 <b>골든크로스 스캔 완료 (선물 모의)</b>\n\n🎯 매수 후보: {{ nodes.filter_not_held.symbols }}\n🔥 신호: MA5 > MA20 상향 돌파\n💡 해석: 단기 추세 전환 가능성 ↑\n\n⏰ 다음 체크: 매일 10:00 HKT\n💡 체결 내역은 LS HTS/MTS 에서 확인하세요.",
      "position": {"x": 1900, "y": 300}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "schedule"},
    {"from": "schedule", "to": "account"},
    {"from": "schedule", "to": "watchlist"},
    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "ma_cross"},
    {"from": "ma_cross", "to": "filter_not_held"},
    {"from": "account", "to": "filter_not_held"},
    {"from": "filter_not_held", "to": "buy_order"},
    {"from": "buy_order", "to": "telegram_gc"}
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_futures",
      "data": [
        {"key": "appkey", "value": "", "type": "password", "label": "App Key"},
        {"key": "appsecret", "value": "", "type": "password", "label": "App Secret"}
      ]
    },
    {
      "credential_id": "telegram_cred",
      "type": "telegram",
      "data": [
        {"key": "bot_token", "value": "", "type": "password", "label": "Bot Token"},
        {"key": "chat_id", "value": "", "type": "text", "label": "Chat ID"}
      ]
    }
  ],
  "notes": [
    {
      "id": "note_strategy",
      "content": "## 골든크로스 자동 매수\n\n**전략**: 추세 추종 (MA5 x MA20)\n**시그널**:\n- 골든크로스 (golden): MA5 가 MA20 을 상향 돌파 → 매수\n- 데드크로스 (dead): MA5 가 MA20 을 하향 돌파 → 매도 (별도 워크플로우)\n\n**스케줄**: 평일 10:00 HKT 일일 체크\n- 전일 종가 기준 크로스 감지\n- 장 시작 후 30분 뒤 진입 (변동성 안정화)\n\n**MA 기간 조정**:\n- 초단기: MA3/MA10 (더 민감, 더 많은 신호)\n- 단기 (기본): MA5/MA20\n- 중기: MA10/MA50\n- 장기: MA50/MA200 (황금교차)\n\n**주의**:\n- MA 크로스는 후행 지표 → 추세 전환을 지연 반영\n- 횡보장에선 잦은 가짜 신호\n- 강한 추세장에서 가장 효과적",
      "color": 6,
      "width": 380,
      "height": 380,
      "position": {"x": 30, "y": 30}
    }
  ]
}

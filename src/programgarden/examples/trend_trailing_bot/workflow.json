{
  "id": "trend_trailing_bot_v2",
  "name": "추세추종 2종목 유지 자동매매 (텔레그램)",
  "description": "항상 2종목 보유 유지. TSMOM 추세 상위 매수 + -5% 손절 매도. 빈 슬롯은 다음 사이클에 자동 충원.",
  "nodes": [
    {"id": "start", "type": "StartNode", "position": {"x": 50, "y": 300}},
    {
      "id": "broker",
      "type": "OverseasStockBrokerNode",
      "credential_id": "broker_cred",
      "paper_trading": false,
      "position": {"x": 200, "y": 300}
    },
    {
      "id": "schedule",
      "type": "ScheduleNode",
      "cron": "*/5 * * * 1-5",
      "timezone": "America/New_York",
      "enabled": true,
      "max_duration_hours": 720,
      "position": {"x": 400, "y": 300}
    },
    {
      "id": "trading_hours",
      "type": "TradingHoursFilterNode",
      "start": "09:30",
      "end": "15:55",
      "timezone": "America/New_York",
      "days": ["mon", "tue", "wed", "thu", "fri"],
      "position": {"x": 600, "y": 300}
    },

    {
      "id": "account",
      "type": "OverseasStockAccountNode",
      "position": {"x": 800, "y": 300}
    },

    {
      "id": "watchlist",
      "type": "WatchlistNode",
      "symbols": [
        {"symbol": "INTC", "exchange": "NASDAQ"},
        {"symbol": "SOFI", "exchange": "NASDAQ"},
        {"symbol": "AUID", "exchange": "NASDAQ"},
        {"symbol": "GOSS", "exchange": "NASDAQ"}
      ],
      "position": {"x": 800, "y": 100}
    },
    {
      "id": "historical",
      "type": "OverseasStockHistoricalDataNode",
      "symbol": "{{ item }}",
      "start_date": "{{ date.ago(90, format='yyyymmdd') }}",
      "end_date": "{{ date.today(format='yyyymmdd') }}",
      "interval": "1d",
      "position": {"x": 1050, "y": 100}
    },
    {
      "id": "tsmom",
      "type": "ConditionNode",
      "plugin": "TimeSeriesMomentum",
      "items": {
        "from": "{{ item.time_series }}",
        "extract": {
          "symbol": "{{ item.symbol }}",
          "exchange": "{{ item.exchange }}",
          "date": "{{ row.date }}",
          "close": "{{ row.close }}"
        }
      },
      "fields": {
        "lookback_days": 20,
        "signal_mode": "binary",
        "volatility_adjust": false
      },
      "position": {"x": 1300, "y": 100}
    },

    {
      "id": "filter_buy",
      "type": "SymbolFilterNode",
      "operation": "difference",
      "input_a": "{{ nodes.tsmom.passed_symbols }}",
      "input_b": "{{ nodes.account.held_symbols }}",
      "position": {"x": 1550, "y": 200}
    },
    {
      "id": "buy_order",
      "type": "OverseasStockNewOrderNode",
      "side": "buy",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": 1
      },
      "position": {"x": 1800, "y": 200}
    },
    {
      "id": "telegram_buy",
      "type": "TelegramNode",
      "credential_id": "telegram_cred",
      "template": "📊 추세 스캔 완료 (INTC, SOFI, AUID, GOSS)",
      "position": {"x": 2050, "y": 200}
    },

    {
      "id": "if_has_positions",
      "type": "IfNode",
      "left": "{{ nodes.account.positions.count() }}",
      "operator": ">",
      "right": 0,
      "position": {"x": 1050, "y": 500}
    },
    {
      "id": "sell_order",
      "type": "OverseasStockNewOrderNode",
      "side": "{{ item.close_side }}",
      "order_type": "market",
      "order": {
        "symbol": "{{ item.symbol }}",
        "exchange": "{{ item.exchange }}",
        "quantity": "{{ item.quantity }}"
      },
      "resilience": {
        "fallback": {"mode": "skip"}
      },
      "position": {"x": 1300, "y": 500}
    },
    {
      "id": "telegram_sell",
      "type": "TelegramNode",
      "credential_id": "telegram_cred",
      "template": "🔴 <b>손절 매도</b>\n포지션 청산",
      "position": {"x": 1300, "y": 500}
    }
  ],
  "edges": [
    {"from": "start", "to": "broker"},
    {"from": "broker", "to": "schedule"},
    {"from": "schedule", "to": "trading_hours"},

    {"from": "trading_hours", "to": "account"},
    {"from": "trading_hours", "to": "watchlist"},

    {"from": "watchlist", "to": "historical"},
    {"from": "historical", "to": "tsmom"},

    {"from": "tsmom", "to": "filter_buy"},
    {"from": "account", "to": "filter_buy"},
    {"from": "filter_buy", "to": "buy_order"},
    {"from": "buy_order", "to": "telegram_buy"},

    {"from": "account", "to": "if_has_positions"},
    {"from": "if_has_positions", "to": "sell_order", "from_port": "true"},
    {"from": "sell_order", "to": "telegram_sell"}
  ],
  "credentials": [
    {
      "credential_id": "broker_cred",
      "type": "broker_ls_overseas_stock",
      "data": [
        {"key": "appkey", "value": "", "type": "password", "label": "App Key"},
        {"key": "appsecret", "value": "", "type": "password", "label": "App Secret"}
      ]
    },
    {
      "credential_id": "telegram_cred",
      "type": "telegram",
      "data": [
        {"key": "bot_token", "value": "", "type": "password", "label": "Bot Token"},
        {"key": "chat_id", "value": "", "type": "text", "label": "Chat ID"}
      ]
    }
  ],
  "notes": [
    {
      "id": "note_strategy",
      "content": "## 2종목 유지 자동매매\n\n**목표**: 항상 2종목 보유 유지\n\n**매수**: watchlist 4종목 TSMOM 추세 평가\n  → 보유종목 제외 → 보유 < 2개면 매수\n  → 빈 자리는 다음 사이클에 자동 충원\n\n**매도**: 보유 포지션 전량 청산\n  (추후 -5% 트레일링 스탑 조건 추가)\n\n**주기**: 5분 (평일 09:30-15:55 ET)",
      "color": 1,
      "width": 360,
      "height": 260,
      "position": {"x": 30, "y": 30}
    }
  ]
}
